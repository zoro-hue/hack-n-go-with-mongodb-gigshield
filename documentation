### 6.3 Route: `POST /api/query` (`routes/query.js`)

```javascript
const router = express.Router();
const { translateQuery } = require("../services/nlpService");
const { executeQuery } = require("../services/mongoService");
const { validateQuery } = require("../middleware/validator");

router.post("/", rateLimiter, async (req, res, next) => {
  try {
    const { question } = req.body;

    if (!question || typeof question !== "string") {
      return res.status(400).json({ error: "question field is required" });
    }

    // Step 1: Translate NL to MongoDB query via AI
    const parsed = await translateQuery(question);

    // Step 2: Validate query is safe to execute
    validateQuery(parsed);

    // Step 3: Execute against MongoDB
    const { results, count } = await executeQuery(parsed);

    // Step 4: Build shell-style query string for display
    const generatedQuery = buildQueryString(parsed);

    res.json({ ...parsed, results, count, generatedQuery });
  } catch (err) {
    next(err);
  }
});
```

### 6.4 Middleware: Query Validator (`middleware/validator.js`)

```javascript
const ALLOWED_OPERATIONS = ["find", "aggregate", "countDocuments"];

const BLOCKED_KEYWORDS = [
  "drop", "delete", "remove", "insert", "update",
  "replace", "createIndex", "dropIndex", "eval"
];

const validateQuery = (parsed) => {
  if (!ALLOWED_OPERATIONS.includes(parsed.operation)) {
    throw new Error(`Operation '${parsed.operation}' is not permitted.`);
  }

  const queryStr = JSON.stringify(parsed).toLowerCase();
  for (const keyword of BLOCKED_KEYWORDS) {
    if (queryStr.includes(keyword)) {
      throw new Error(`Query contains restricted keyword: '${keyword}'`);
    }
  }
};
```

