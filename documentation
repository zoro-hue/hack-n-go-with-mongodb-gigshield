### 5.3 Custom Hooks

#### `useQuery.js`

```javascript
// Sends POST /api/query and returns { result, loading, error }
export const useQuery = () => {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  const execute = async (question) => {
    setLoading(true);
    try {
      const { data } = await axios.post("/api/query", { question });
      return data;
    } catch (err) {
      setError(err.response?.data?.message || "Query failed");
    } finally {
      setLoading(false);
    }
  };

  return { execute, loading, error };
};
```

