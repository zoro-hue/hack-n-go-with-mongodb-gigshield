### 8.2 Query Execution (`services/mongoService.js`)

```javascript
const mongoose = require("mongoose");

const executeQuery = async ({ collection, operation, query, options, pipeline }) => {
  const db = mongoose.connection.db;
  const col = db.collection(collection);

  let results;

  if (operation === "find") {
    const cursor = col.find(query || {});
    if (options?.sort) cursor.sort(options.sort);
    if (options?.limit) cursor.limit(options.limit);
    if (options?.projection) cursor.project(options.projection);
    results = await cursor.toArray();
  } else if (operation === "aggregate") {
    results = await col.aggregate(pipeline).toArray();
  } else if (operation === "countDocuments") {
    const count = await col.countDocuments(query || {});
    results = [{ count }];
  }

  return { results, count: results.length };
};
```

### 8.3 Schema Introspection (`services/schemaService.js`)

```javascript
// Samples up to 100 documents per collection to infer field names
const getSchema = async () => {
  const db = mongoose.connection.db;
  const collections = await db.listCollections().toArray();
  const schema = {};

  for (const { name } of collections) {
    const sample = await db.collection(name).find().limit(100).toArray();
    const fields = new Set();
    sample.forEach(doc => Object.keys(doc).forEach(k => fields.add(k)));
    schema[name] = [...fields];
  }

  return schema;
};
```

